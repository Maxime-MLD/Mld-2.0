---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Realisations from '../components/Realisations.astro';
// import Temoignages from '../components/Temoignages.astro'; // en pause — remplacé par Process
import Process from '../components/Process.astro';
import Faq from '../components/Faq.astro';
import CtaFinal from '../components/CtaFinal.astro';

/*
  Page d'accueil — assemble toutes les sections dans l'ordre défini :
  Hero → Clients → Stats → Services → À propos → Réalisations →
  Témoignages → FAQ → CTA final.
*/
---

<Layout>
  <Hero />
  <TrustBar />
  <Stats />
  <Services />
  <About />
  <Realisations />
  {/* <Temoignages /> — en pause, conservé pour réactivation ultérieure */}
  <Process />
  <Faq />
  <CtaFinal />
</Layout>
