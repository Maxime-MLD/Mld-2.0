---
/*
  Footer — navigation, contact, mentions légales.
  Coordonnées en placeholders à compléter.
*/

import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#services', label: 'Services' },
  { href: '#a-propos', label: 'À propos' },
  { href: '#realisations', label: 'Réalisations' },
  { href: '#process', label: 'Méthode' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];

const contact = {
  phone: '06 62 59 97 71',
  email: 'contact@mld-dev.com',
  address: '41 chemin de Villevert, 42720 Vougy',
};

// Réseaux sociaux + fiche Google. Icônes officielles (Simple Icons), monochromes.
const socials = [
  {
    label: 'MLD sur Facebook',
    href: '[LIEN_FACEBOOK]',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  {
    label: 'MLD sur Instagram',
    href: '[LIEN_INSTAGRAM]',
    path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  {
    label: 'MLD sur LinkedIn',
    href: 'www.linkedin.com/in/maxime-lagraa-4a4299386',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    label: 'Avis Google de MLD',
    href: 'https://g.page/r/CS8mjzvXV0OrEAE/review',
    path: 'M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z',
  },
];
---

<footer data-anim="footer" class="border-t border-ink/10 bg-canvas">
  <div class="container-mld grid grid-cols-1 gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4 lg:py-22">
    <!-- Marque -->
    <div class="lg:col-span-1">
      <a href="#hero" class="inline-flex items-center" aria-label="MLD — accueil">
        <Image src={logo} alt="Logo MLD — agence web" format="webp" class="h-12 w-auto" />
      </a>
      <p class="mt-4 max-w-xs font-sans text-sm leading-relaxed text-ink/60">
        Agence web à Roanne. Sites vitrine modernes et refonte de sites anciens
        pour gagner en visibilité et trouver de nouveaux clients.
      </p>

      <!-- Réseaux sociaux + fiche Google -->
      <ul class="mt-6 flex items-center gap-1">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-10 w-10 items-center justify-center rounded-lg text-ink/70 transition-colors hover:bg-ink/5 hover:text-accent"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={s.path} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Navigation -->
    <nav aria-label="Navigation pied de page">
      <h3 class="font-heading text-sm font-bold uppercase tracking-wide text-ink/40">Navigation</h3>
      <ul class="mt-4 space-y-3">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="font-sans text-sm text-ink/70 transition-colors hover:text-accent">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Contact -->
    <div>
      <h3 class="font-heading text-sm font-bold uppercase tracking-wide text-ink/40">Contact</h3>
      <ul class="mt-4 space-y-3 font-sans text-sm text-ink/70">
        <li><a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="transition-colors hover:text-accent">{contact.phone}</a></li>
        <li><a href={`mailto:${contact.email}`} class="transition-colors hover:text-accent">{contact.email}</a></li>
        <li>Roanne &amp; Loire</li>
      </ul>
    </div>

    <!-- Mentions légales -->
    <div>
      <h3 class="font-heading text-sm font-bold uppercase tracking-wide text-ink/40">Informations</h3>
      <ul class="mt-4 space-y-3 font-sans text-sm text-ink/70">
        <li><a href="/mentions-legales" class="transition-colors hover:text-accent">Mentions légales</a></li>
        <li><a href="/politique-confidentialite" class="transition-colors hover:text-accent">Politique de confidentialité</a></li>
      </ul>
    </div>
  </div>

  <!-- Bas de footer -->
  <div class="border-t border-ink/10">
    <div class="container-mld flex flex-col items-center justify-between gap-4 py-6 sm:flex-row">
      <p class="font-sans text-xs text-ink/50">© {year} MLD. Tous droits réservés.</p>
      <p class="font-sans text-xs text-ink/50">Création de sites internet à Roanne &amp; dans la Loire</p>
    </div>
  </div>
</footer>
