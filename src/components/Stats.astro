---
/*
  Stats — section problème / prise de conscience.
  AUCUNE statistique inventée : placeholders [XX% – source à vérifier]
  à remplacer par de vrais chiffres sourcés (cf. légende en bas de section).
  Animations : voir bloc // === STATS / PROBLÈME === dans Animation.jsx.
*/

const stats = [
  {
    value: '97%',
    label: 'des gens utilisent internet pour trouver et découvrir une entreprise locale',
    source: 'Source Google',
  },
  {
    value: '75%',
    label: `des utilisateurs jugent la crédibilité et le sérieux d'une entreprise locale sur l'aspect de son site internet`,
    source: 'Source, Université de Stanford - San Francisco',
  },
  {
    value: '46%',
    label: 'de toutes les recherches quotidiennes sur Google ont une "intention locale"',
    source: 'Source Google',
  },
];
---

<section aria-labelledby="stats-title" class="relative isolate overflow-hidden bg-ink text-canvas">
  <!-- Halos d'accent décoratifs — angle haut-gauche et bas-droit, moitié visible -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-0 top-0 -z-10 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-accent/20 blur-3xl"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 right-0 -z-10 h-[420px] w-[420px] translate-x-1/2 translate-y-1/4 rounded-full bg-accent/20 blur-3xl"
  >
  </div>

  <div class="container-mld py-22 sm:py-30">
    <div class="mx-auto max-w-2xl text-center">
      <p
        data-anim="stats-eyebrow"
        class="font-sans text-sm font-semibold uppercase tracking-widest text-accent"
      >
        Le constat
      </p>
      <h2
        id="stats-title"
        data-anim="stats-title"
        class="mt-6 font-heading text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl"
      >
        Sans site web, vous perdez des clients chaque jour
      </h2>
      <p
        data-anim="stats-subtitle"
        class="mx-auto mt-6 max-w-xl font-sans text-lg leading-relaxed text-canvas/70"
      >
        Vos clients vous cherchent en ligne. Sans site — ou avec un site dépassé — ils vont chez la concurrence.
      </p>
    </div>

    <dl class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-6">
      {
        stats.map((stat) => (
          <div
            data-anim="stats-item"
            class="rounded-2xl border border-canvas/10 bg-canvas/5 p-8 text-center"
          >
            <dt class="font-heading text-4xl font-extrabold text-accent sm:text-5xl">
              {stat.value}
            </dt>
            <dd class="mt-4 font-sans text-base leading-relaxed text-canvas/80">
              {stat.label}
            </dd>
            <dd class="mt-3 font-sans text-xs italic text-canvas/40">{stat.source}</dd>
          </div>
        ))
      }
    </dl>

    <!-- <p
      data-anim="stats-legend"
      class="mt-10 text-center font-sans text-xs text-canvas/40"
    >
      Chiffres à compléter avec des sources fiables et vérifiables (ex. études
      sectorielles, INSEE, Google). Remplacez chaque [XX%] et [source à vérifier].
    </p> -->
  </div>
</section>
