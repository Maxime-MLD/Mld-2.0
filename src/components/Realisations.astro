---
/*
  Realisations — « Mes créations » : exemples de sites de démonstration créés
  par MLD pour illustrer le savoir-faire (PAS des projets clients livrés).
  Grille 2 cards/ligne (desktop) → 1/ligne (mobile). Images non rognées
  (object-contain) dans un ratio uniforme pour une grille régulière.
  Bouton « Voir le site » volontairement inactif (« Bientôt en ligne »).
  Animations : voir bloc // === RÉALISATIONS === dans Animation.jsx.
*/
import { Image } from 'astro:assets';
import demoDentiste from '../assets/service_dentiste.png';
import demoMacon from '../assets/service_macon.png';
import demoMenuiserie from '../assets/hero_2026.png';
import demoAgence from '../assets/hero_mld.png';

const creations = [
  {
    image: demoDentiste,
    alt: 'Exemple de site vitrine pour un cabinet dentaire, créé par MLD',
    name: 'Site pour un cabinet dentaire',
    type: 'Site vitrine multi-pages avec formulaire de contact',
  },
  {
    image: demoMacon,
    alt: 'Exemple de site vitrine multi-pages pour un maçon, créé par MLD',
    name: 'Site pour un maçon',
    type: 'Site vitrine multi-pages avec animations au scroll',
  },
  {
    image: demoMenuiserie,
    alt: 'Exemple de refonte de site pour une menuiserie, créé par MLD',
    name: 'Site pour une Menuiserie',
    type: 'Refonte de site',
  },
  {
    image: demoAgence,
    alt: 'Exemple de landing page d\'agence web, créé par MLD',
    name: 'Agence web',
    type: 'Site vitrine mono-page avec formulaire de contact',
  },
];
---

<section id="realisations" aria-labelledby="realisations-title" class="bg-canvas">
  <div class="container-mld py-22 sm:py-30">
    <!-- En-tête -->
    <div class="max-w-2xl">
      <p
        data-anim="real-eyebrow"
        class="font-sans text-sm font-semibold uppercase tracking-widest text-accent"
      >
        Mes créations
      </p>
      <h2
        id="realisations-title"
        data-anim="real-title"
        class="mt-6 font-heading text-3xl font-extrabold leading-tight tracking-tight text-ink sm:text-4xl lg:text-5xl"
      >
        Un aperçu de ce que je réalise
      </h2>
      <p
        data-anim="real-subtitle"
        class="mt-6 font-sans text-lg leading-relaxed text-ink/70"
      >
        Des sites sur-mesure, pensés pour différents métiers.
      </p>
    </div>

    <!-- Galerie épurée façon Apple — images seules -->
    <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-10">
      {
        creations.map((item) => (
          <div
            data-anim="real-card"
            class="group aspect-[16/10] overflow-hidden rounded-3xl bg-white shadow-[0_18px_40px_-12px_rgba(6,9,24,0.18)] ring-1 ring-ink/5 transition-all duration-500 ease-out hover:-translate-y-1 hover:shadow-[0_28px_56px_-12px_rgba(6,9,24,0.26)]"
          >
            <Image
              src={item.image}
              alt={item.alt}
              class="h-full w-full object-contain transition-transform duration-700 ease-out group-hover:scale-[1.04]"
            />
          </div>
        ))
      }
    </div>

    <!-- CTA unique en bas de section -->
    <div class="mt-16 text-center sm:mt-20">
      <p class="mx-auto max-w-xl font-heading text-2xl font-bold tracking-tight text-ink sm:text-3xl">
        Et si le prochain, c'était le vôtre&nbsp;?
      </p>
      <a href="#contact" class="btn-primary mt-8">Me contacter</a>
    </div>
  </div>
</section>
