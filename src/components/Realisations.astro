---
/*
  Realisations — « Mes créations » : exemples de sites de démonstration créés
  par MLD pour illustrer le savoir-faire (PAS des projets clients livrés).
  Grille 2 cards/ligne (desktop) → 1/ligne (mobile). Images non rognées
  (object-contain) dans un ratio uniforme pour une grille régulière.
  Bouton « Voir le site » volontairement inactif (« Bientôt en ligne »).
  Animations : voir bloc // === RÉALISATIONS === dans Animation.jsx.
*/
import { Image } from 'astro:assets';
import demoDentiste from '../assets/service_dentiste.png';
import demoMacon from '../assets/service_macon.png';
import demoMenuiserie from '../assets/hero_2026.png';
import demoAgence from '../assets/hero_mld.png';

const creations = [
  {
    image: demoDentiste,
    alt: 'Exemple de site vitrine pour un cabinet dentaire, créé par MLD',
    name: 'Site pour un cabinet dentaire',
    type: 'Site vitrine multi-pages avec formulaire de contact',
  },
  {
    image: demoMacon,
    alt: 'Exemple de site vitrine multi-pages pour un maçon, créé par MLD',
    name: 'Site pour un maçon',
    type: 'Site vitrine multi-pages avec animations au scroll',
  },
  {
    image: demoMenuiserie,
    alt: 'Exemple de refonte de site pour une menuiserie, créé par MLD',
    name: 'Site pour une Menuiserie',
    type: 'Refonte de site',
  },
  {
    image: demoAgence,
    alt: 'Exemple de landing page d\'agence web, créé par MLD',
    name: 'Agence web',
    type: 'Site vitrine mono-page avec formulaire de contact',
  },
];
---

<section id="realisations" aria-labelledby="realisations-title" class="bg-canvas">
  <div class="container-mld py-22 sm:py-30">
    <!-- En-tête -->
    <div class="max-w-2xl">
      <p
        data-anim="real-eyebrow"
        class="font-sans text-sm font-semibold uppercase tracking-widest text-accent"
      >
        Mes créations
      </p>
      <h2
        id="realisations-title"
        data-anim="real-title"
        class="mt-6 font-heading text-3xl font-extrabold leading-tight tracking-tight text-ink sm:text-4xl lg:text-5xl"
      >
        Un aperçu de ce que je réalise
      </h2>
      <p
        data-anim="real-subtitle"
        class="mt-6 font-sans text-lg leading-relaxed text-ink/70"
      >
        Voici des exemples de sites que je conçois pour différents métiers&nbsp;:
        des démonstrations pour vous montrer concrètement mon savoir-faire.
      </p>
    </div>

    <!-- Grille de créations -->
    <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2">
      {
        creations.map((item) => (
          <article
            data-anim="real-card"
            class="group flex flex-col overflow-hidden rounded-2xl border border-ink/10 bg-white/60 shadow-[0_12px_32px_-8px_rgba(6,9,24,0.14)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_44px_-10px_rgba(6,9,24,0.20)]"
          >
            {/* Visuel — ratio uniforme, image entière (object-contain), zoom hover discret */}
            <div class="aspect-[16/10] overflow-hidden border-b border-ink/10 bg-canvas">
              <Image
                src={item.image}
                alt={item.alt}
                class="h-full w-full object-contain transition-transform duration-500 ease-out group-hover:scale-[1.04]"
              />
            </div>

            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-heading text-lg font-bold text-ink">{item.name}</h3>
              <p class="mt-1 font-sans text-sm text-ink/60">{item.type}</p>

              {/* Tag commercial uniforme : site disponible à l'achat */}
              <div class="mt-4">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-2.5 py-1 font-sans text-xs font-semibold text-accent">
                  Site disponible
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
                    <path d="m5 12 5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>

              {/* Invitation à me contacter (le site est achetable / adaptable) */}
              <p class="mt-auto pt-6 font-sans text-sm leading-relaxed text-ink/70">
                Ce site vous intéresse pour votre entreprise&nbsp;?{' '}
                <a
                  href="#contact"
                  class="font-semibold text-accent underline-offset-4 hover:underline"
                >
                  Écrivez-moi.
                </a>
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
